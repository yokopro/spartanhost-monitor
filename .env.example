# ==========================================
# 斯巴达监控环境变量配置模板
# 使用方法：复制本文件并重命名为 .env，然后填写实际参数
# ==========================================

# SMTP 账户设置
# Gmail 用户请使用“应用专用密码”，而非登录密码
EMAIL_USER=your-account@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# SMTP 服务器设置 (Gmail 默认如下)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# 管理后台密码
ADMIN_PASSWORD=SetYourOwnStrongPassword

# 代理设置 (可选)
# EMAIL_PROXY=http://127.0.0.1:7890